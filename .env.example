# ── Database (local native Postgres, no Docker) ──
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/my_makaranta?schema=public

# ── Redis (local native, no Docker) ──
REDIS_URL=redis://localhost:6379

# ── Auth ──
JWT_SECRET=dev-secret-change-me

# ── App URLs ──
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
PORT=4000

# ── Storage: "local" (dev, writes to .storage/) or "s3" (prod) ──
STORAGE_PROVIDER=local
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── SMS: "mock" (dev/test) or "termii" (prod) ──
SMS_PROVIDER=mock
TERMII_API_KEY=
TERMII_SENDER_ID=myMakaranta

# ── Email: "log" (dev/test) or "mailgun" (prod) ──
EMAIL_PROVIDER=log
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_FROM=noreply@mymakaranta.com

# ── Payments: "mock" (test) or "paystack" (prod) ──
PAYMENT_PROVIDER=mock
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
